# ========================================
# 🔧 APPLICATION
# ========================================
NODE_ENV=development
APP_ENV=sandbox                    # sandbox | production
PORT=3000
LOG_LEVEL=debug

# ========================================
# 🔒 CADDY (HTTPS)
# ========================================
CADDY_DOMAIN=localhost            # Domínio para Let's Encrypt (ex: api.seudominio.com)
CADDY_EMAIL=admin@yourdomain.com   # Email para registro Let's Encrypt

# ========================================
# 🔔 ALERTS (SLACK)
# ========================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ========================================
# 🔐 SECURITY
# ========================================
API_KEY=your-api-key-here          # Header: X-API-Key
WEBHOOK_SECRET=your-webhook-secret

# ========================================
# 💰 PAYMENT PROVIDER
# ========================================
PAYMENT_PROVIDER=mercadopago
PAYMENT_MODE=sandbox               # sandbox | production

# Mercado Pago
MP_ACCESS_TOKEN=TEST-xxx
MP_WEBHOOK_SECRET=xxx
MP_NOTIFICATION_URL=https://your-domain.com/webhooks/mercadopago

# ========================================
# 🗄️ DATABASE
# ========================================
DATABASE_URL=postgresql://gateway:gateway_secret@localhost:5432/gateway
DATABASE_POOL_SIZE=10

# ========================================
# 📦 REDIS
# ========================================
REDIS_URL=redis://localhost:6379
REDIS_TTL_IDEMPOTENCY=86400        # 24h em segundos
REDIS_TTL_RATE_LIMIT=60            # 1 minuto

# ========================================
# 🐰 RABBITMQ
# ========================================
RABBITMQ_URL=amqp://gateway:gateway_secret@localhost:5672
RABBITMQ_RETRY_ATTEMPTS=3
RABBITMQ_RETRY_DELAY=5000          # ms

# ========================================
# 🔔 NOTIFICATIONS
# ========================================
FEATURE_NOTIFICATION=true
WEBSOCKET_PORT=3003

# Firebase (opcional)
FEATURE_FIREBASE=false
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# ========================================
# ✉️ EMAIL
# ========================================
FEATURE_EMAIL=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# ========================================
# 🎛️ FEATURE FLAGS
# ========================================
FEATURE_PIX=true
FEATURE_CARD=false
FEATURE_SANDBOX_ENDPOINTS=true     # Habilita /sandbox/*
